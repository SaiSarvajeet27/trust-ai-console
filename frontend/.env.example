# Leave VITE_API_BASE empty to use the Vite proxy (recommended for dev).
# Only set this for production builds pointing to a deployed API.
# VITE_API_BASE=http://localhost:8000

# Google OAuth Client ID (optional — leave empty to skip Google Sign-In)
# Get one from https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=
